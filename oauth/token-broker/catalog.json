{
  "oauth_providers": {
    "keycloak-tyk-demo": {
      "token_url": "http://keycloak:8080/realms/tyk-demo/protocol/openid-connect/token",
      "client_id": "tyk-broker",
      "client_secret": "broker-secret"
    }
  },
  "tenants": {
    "tenant-a": {
      "integrations": {
        "construcao": {
          "target_url": "http://upstream:3000",
          "auth": {
            "type": "api-key",
            "header_name": "X-Api-Key",
            "header_value": "demo-httpbin-key"
          },
          "operations": {
            "consultar-certidao": {
              "path": "/api/construcao/v1/certidoes/123",
              "method": "GET"
            }
          }
        },
        "educacao": {
          "target_url": "http://protected-api:3000",
          "auth": {
            "type": "bearer",
            "oauth_provider": "keycloak-tyk-demo"
          },
          "operations": {
            "emitir-historico": {
              "path": "/api/educacao/v1/historico",
              "method": "GET"
            }
          }
        },
        "saude": {
          "target_url": "http://upstream:3000",
          "auth": {
            "type": "basic",
            "username": "demo-echo",
            "password": "demo-echo-pass"
          },
          "operations": {
            "agendar-consulta": {
              "path": "/api/saude/v1/consultas",
              "method": "POST"
            }
          }
        }
      }
    }
  }
}
