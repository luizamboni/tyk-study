{
  "name": "Upstream autenticado por query string",
  "api_id": "upstream-query-api",
  "org_id": "demo-org",
  "use_keyless": false,
  "strip_auth_data": true,
  "auth": { "auth_header_name": "Authorization" },
  "auth_configs": {
    "authToken": { "auth_header_name": "Authorization" }
  },
  "active": true,
  "proxy": {
    "listen_path": "/services/query-auth/",
    "target_url": "http://upstream/",
    "strip_listen_path": true
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "extended_paths": {
          "url_rewrites": [
            {
              "path": "anything",
              "method": "GET",
              "match_pattern": "anything",
              "rewrite_to": "anything?api_key=$secret_env.UPSTREAM_QUERY_API_KEY"
            }
          ]
        }
      }
    }
  }
}
