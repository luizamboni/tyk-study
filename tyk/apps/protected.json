{
  "name": "API protegida por token",
  "api_id": "protected-api",
  "org_id": "demo-org",
  "use_keyless": false,
  "auth": { "auth_header_name": "Authorization" },
  "auth_configs": {
    "authToken": { "auth_header_name": "Authorization" }
  },
  "active": true,
  "proxy": {
    "listen_path": "/protected/",
    "target_url": "http://upstream/",
    "strip_listen_path": true
  },
  "version_data": {
    "not_versioned": true,
    "versions": { "Default": { "name": "Default", "use_extended_paths": true } }
  }
}
