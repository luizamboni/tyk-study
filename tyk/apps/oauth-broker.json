{
  "name": "API externa OAuth via token broker",
  "api_id": "oauth-broker-api",
  "org_id": "demo-org",
  "use_keyless": false,
  "strip_auth_data": true,
  "auth": { "auth_header_name": "Authorization" },
  "auth_configs": {
    "authToken": { "auth_header_name": "Authorization" }
  },
  "active": true,
  "proxy": {
    "listen_path": "/services/oauth/",
    "target_url": "http://token-broker:3000/",
    "strip_listen_path": true
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": { "name": "Default", "use_extended_paths": true }
    }
  }
}
