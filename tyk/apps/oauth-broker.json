{
  "name": "Integrações via plugin Go",
  "api_id": "oauth-broker-api",
  "org_id": "demo-org",
  "use_keyless": false,
  "strip_auth_data": false,
  "auth": { "auth_header_name": "Authorization" },
  "auth_configs": {
    "authToken": { "auth_header_name": "Authorization" }
  },
  "active": true,
  "global_rate_limit": { "rate": 100, "per": 60 },
  "proxy": {
    "listen_path": "/api/integration/",
    "target_url": "http://protected-api:3000/",
    "strip_listen_path": false
  },
  "custom_middleware": {
    "pre": [],
    "post_key_auth": [
      {
        "name": "RouteIntegration",
        "path": "/opt/tyk-gateway/middleware/IntegrationBroker_v5.8.5_linux_arm64.so",
        "require_session": true,
        "raw_body_only": false
      }
    ],
    "post": [],
    "driver": "goplugin"
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "global_headers": {
          "X-Integration-Gateway": "Tyk",
          "X-Rate-Limit-Policy": "100-per-minute"
        },
        "global_headers_remove": ["X-Internal-Debug"]
      }
    }
  }
}
