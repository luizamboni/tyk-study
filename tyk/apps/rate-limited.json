{
  "name": "API com rate limit global",
  "api_id": "rate-limited-api",
  "org_id": "demo-org",
  "use_keyless": true,
  "active": true,
  "global_rate_limit": { "rate": 3, "per": 10 },
  "proxy": {
    "listen_path": "/limited/",
    "target_url": "http://upstream/",
    "strip_listen_path": true
  },
  "version_data": {
    "not_versioned": true,
    "versions": { "Default": { "name": "Default", "use_extended_paths": true } }
  }
}
