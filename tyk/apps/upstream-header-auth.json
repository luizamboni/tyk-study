{
  "name": "Upstream autenticado por cabecalho",
  "api_id": "upstream-header-api",
  "org_id": "demo-org",
  "use_keyless": false,
  "strip_auth_data": true,
  "auth": { "auth_header_name": "Authorization" },
  "auth_configs": {
    "authToken": { "auth_header_name": "Authorization" }
  },
  "active": true,
  "proxy": {
    "listen_path": "/services/header-auth/",
    "target_url": "http://upstream/",
    "strip_listen_path": true
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "global_headers": {
          "X-Upstream-Api-Key": "$secret_env.UPSTREAM_HEADER_API_KEY"
        },
        "global_headers_remove": ["Authorization"]
      }
    }
  }
}
